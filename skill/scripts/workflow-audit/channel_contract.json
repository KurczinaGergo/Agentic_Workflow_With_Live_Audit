{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentic Workflow Channel Transcript Entry",
  "type": "object",
  "required": [
    "message_id",
    "run_id",
    "timestamp",
    "delegation_id",
    "channel_id",
    "channel_kind",
    "workflow_label",
    "source_agent_id",
    "target_agent_id",
    "role",
    "message_type",
    "body",
    "artifact_refs",
    "related_event_id"
  ],
  "properties": {
    "message_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "delegation_id": {
      "type": "string"
    },
    "channel_id": {
      "type": "string"
    },
    "channel_kind": {
      "type": "string"
    },
    "workflow_label": {
      "type": "string"
    },
    "source_agent_id": {
      "type": "string"
    },
    "target_agent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "role": {
      "type": "string"
    },
    "message_type": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_event_id": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
